# Copy to .env and fill in. .env is gitignored.

# Weights & Biases — run `wandb login` instead if you prefer.
WANDB_API_KEY=
WANDB_PROJECT=kg-llm-completion
WANDB_ENTITY=

# Hugging Face — needed to push checkpoints / pull gated models.
HF_TOKEN=

# Optional: override default cache locations (useful on Kaggle/Colab).
# HF_HOME=/kaggle/working/hf_cache
# TRANSFORMERS_CACHE=/kaggle/working/hf_cache
